<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Abonnement - Sentinelle</title>
    <!-- Police moderne -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            /* Couleurs Soft & Modernes */
            --bg-body: #F4F7FE;
            --bg-card: #FFFFFF;
            
            --primary: #4318FF; /* Bleu électrique SaaS */
            --primary-light: #F0EDFF;
            --primary-hover: #3311DB;
            
            --success: #05CD99;
            --success-bg: #E6FBF5;
            
            --text-main: #1E293B;
            --text-muted: #64748B;
            --text-light: #94A3B8;
            
            --border-color: #E2E8F0;
            
            --shadow-sm: 0 2px 4px rgba(15, 23, 42, 0.04);
            --shadow-md: 0 10px 25px rgba(112, 144, 176, 0.08);
            --shadow-hover: 0 20px 40px rgba(67, 24, 255, 0.15);
            
            --radius-md: 16px;
            --radius-lg: 24px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; }

        body { display: flex; height: 100vh; background-color: var(--bg-body); color: var(--text-main); overflow: hidden; }

        /* --- SIDEBAR --- */
        .sidebar {
            width: 260px; background: white; display: flex; flex-direction: column; padding: 24px 20px;
            border-right: 1px solid var(--border-color); z-index: 10;
        }
        .logo { font-size: 20px; font-weight: 800; display: flex; align-items: center; gap: 10px; margin-bottom: 40px; color: var(--primary); }
        .logo i { background: var(--primary); color: white; padding: 8px; border-radius: 8px; }
        .logo span.version { font-size: 11px; color: var(--text-light); font-weight: 500; margin-left: auto; }
        
        .nav-title { font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--text-light); margin: 20px 0 10px 10px; letter-spacing: 1px; }
        .nav-list { list-style: none; }
        .nav-item {
            display: flex; align-items: center; gap: 12px; padding: 12px 14px; border-radius: 12px;
            color: var(--text-muted); font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.2s; margin-bottom: 4px;
        }
        .nav-item:hover { background: var(--primary-light); color: var(--primary); }
        .nav-item.active { background: var(--primary); color: white; box-shadow: 0 4px 12px rgba(67, 24, 255, 0.2); }
        .nav-item i { width: 20px; text-align: center; font-size: 16px; }
        .sidebar-bottom { margin-top: auto; border-top: 1px dashed var(--border-color); padding-top: 20px; }

        /* --- MAIN CONTENT --- */
        .main-content { flex: 1; overflow-y: auto; padding: 30px 40px; }

        /* Topbar */
        .topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        .company-tag { background: white; padding: 6px 16px; border-radius: 20px; font-size: 13px; font-weight: 700; border: 1px solid var(--border-color); }
        .user-profile { display: flex; align-items: center; gap: 10px; font-weight: 600; font-size: 14px; color: var(--text-muted); }

        /* Typography & Utils */
        .page-title { font-size: 28px; font-weight: 800; color: var(--text-main); margin-bottom: 8px; letter-spacing: -0.5px; }
        .page-subtitle { font-size: 15px; color: var(--text-muted); margin-bottom: 30px; }
        .section-title { font-size: 18px; font-weight: 700; margin: 40px 0 20px 0; display: flex; align-items: center; gap: 10px; }
        
        .btn { padding: 10px 20px; border-radius: 12px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; transition: 0.2s; display: inline-flex; align-items: center; gap: 8px; }
        .btn-primary { background: var(--primary); color: white; }
        .btn-primary:hover { background: var(--primary-hover); transform: translateY(-1px); box-shadow: var(--shadow-sm); }
        .btn-outline { background: white; color: var(--text-main); border: 1px solid var(--border-color); }
        .btn-outline:hover { background: #F8FAFC; }

        /* Trial Banner */
        .trial-banner {
            background: linear-gradient(135deg, var(--success-bg), #C6F6D5);
            border-radius: var(--radius-lg); padding: 24px 30px; margin-bottom: 30px;
            display: flex; justify-content: space-between; align-items: center;
            border: 1px solid rgba(5, 205, 153, 0.2);
        }
        .trial-info h3 { color: #047857; font-size: 24px; font-weight: 800; margin-bottom: 4px; display: flex; align-items: center; gap: 10px; }
        .trial-info p { color: #065F46; font-size: 14px; }
        .trial-text { color: #065F46; font-size: 14px; font-weight: 500; text-align: right; max-width: 300px; }

        /* Current Plan Card */
        .current-plan-card {
            background: white; border-radius: var(--radius-lg); padding: 30px; margin-bottom: 40px;
            box-shadow: var(--shadow-md); position: relative; overflow: hidden;
        }
        /* Illustration abstraite en fond */
        .current-plan-card::after {
            content: '\f0a3'; font-family: 'FontAwesome'; position: absolute; right: -20px; top: -30px;
            font-size: 200px; color: var(--primary-light); opacity: 0.4; pointer-events: none;
        }
        .plan-header { margin-bottom: 24px; position: relative; z-index: 1; }
        .plan-header p { font-size: 12px; font-weight: 700; text-transform: uppercase; color: var(--primary); letter-spacing: 1px; margin-bottom: 4px; }
        .plan-header h2 { font-size: 32px; font-weight: 800; color: var(--primary); }
        
        .plan-features-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 30px; position: relative; z-index: 1; }
        .feature-item { display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--text-main); }
        .feature-item i { color: var(--primary); background: var(--primary-light); padding: 4px; border-radius: 50%; font-size: 10px; }
        
        .plan-footer { display: flex; justify-content: flex-end; position: relative; z-index: 1; }

        /* Pricing Grid */
        .pricing-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 50px; }
        
        .pricing-card {
            background: white; border-radius: var(--radius-lg); padding: 30px 24px;
            box-shadow: var(--shadow-sm); border: 1px solid var(--border-color);
            display: flex; flex-direction: column; transition: 0.3s; position: relative;
        }
        
        /* Mise en avant de la carte Premium */
        .pricing-card.highlight {
            border-color: var(--primary); box-shadow: var(--shadow-hover); transform: translateY(-5px);
        }
        .highlight-badge {
            position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
            background: var(--primary); color: white; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 700;
        }

        /* "Illustrations" des prix (Icônes stylisées) */
        .illustration-icon {
            width: 50px; height: 50px; border-radius: 16px; display: flex; align-items: center; justify-content: center;
            font-size: 24px; margin-bottom: 20px;
        }
        .icon-starter { background: #F1F5F9; color: #64748B; }
        .icon-standard { background: var(--primary-light); color: var(--primary); }
        .icon-premium { background: linear-gradient(135deg, var(--primary), #8B5CF6); color: white; }
        .icon-enterprise { background: #FFF7ED; color: #F97316; }

        .pricing-card h3 { font-size: 18px; font-weight: 800; margin-bottom: 4px; }
        .pricing-card .price { font-size: 14px; color: var(--text-muted); margin-bottom: 24px; }
        .badge-current { background: var(--primary-light); color: var(--primary); padding: 2px 8px; border-radius: 6px; font-size: 11px; vertical-align: middle; margin-left: 8px;}
        
        .pricing-features { list-style: none; margin-bottom: 30px; flex-grow: 1; }
        .pricing-features li { display: flex; gap: 10px; font-size: 13px; color: var(--text-muted); margin-bottom: 12px; line-height: 1.4; }
        .pricing-features li i { color: var(--primary); margin-top: 3px; font-size: 12px; }
        
        .pricing-card button { width: 100%; justify-content: center; margin-top: auto; }

        /* Empty States (Illustrations) */
        .empty-state-card {
            background: white; border-radius: var(--radius-lg); padding: 50px 30px;
            text-align: center; border: 1px dashed var(--border-color);
            display: flex; flex-direction: column; align-items: center;
        }
        
        /* Composition d'une "illustration" en CSS */
        .illustration-wrapper {
            position: relative; width: 120px; height: 120px; margin-bottom: 20px;
            display: flex; align-items: center; justify-content: center;
        }
        .illus-bg-blob {
            position: absolute; width: 100%; height: 100%;
            background: var(--primary-light); border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%;
            animation: morph 8s ease-in-out infinite; z-index: 0;
        }
        .illus-icon { font-size: 48px; color: var(--primary); z-index: 1; filter: drop-shadow(0 10px 15px rgba(67, 24, 255, 0.2)); }
        
        @keyframes morph {
            0%, 100% { border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; }
            34% { border-radius: 70% 30% 50% 50% / 30% 30% 70% 70%; }
            67% { border-radius: 100% 60% 60% 100% / 100% 100% 60% 60%; }
        }

        .empty-state-card p { font-size: 15px; color: var(--text-muted); margin-bottom: 20px; font-weight: 500; }

        .footer-support { text-align: center; margin-top: 60px; font-size: 14px; color: var(--text-muted); }
        .footer-support a { color: var(--primary); font-weight: 700; text-decoration: none; }

    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="logo">
            <i class="fa-solid fa-chart-pie"></i> Sentinelle <span class="version">v2.4</span>
        </div>

        <ul class="nav-list">
            <li class="nav-item"><i class="fa-solid fa-box"></i> Ventes</li>
            <li class="nav-item"><i class="fa-solid fa-briefcase"></i> Projets</li>
            <li class="nav-item"><i class="fa-solid fa-users"></i> Mon équipe</li>
            <li class="nav-item"><i class="fa-solid fa-address-book"></i> Clients</li>
            <li class="nav-item"><i class="fa-solid fa-bell"></i> Alertes</li>
            <li class="nav-item"><i class="fa-solid fa-sliders"></i> Simulateur</li>
            <li class="nav-item"><i class="fa-solid fa-table-cells-large"></i> Mes tableaux</li>
        </ul>

        <div class="nav-title">Espace</div>
        <ul class="nav-list">
            <li class="nav-item active"><i class="fa-solid fa-credit-card"></i> Abonnement</li>
            <li class="nav-item"><i class="fa-solid fa-plug"></i> Intégrations</li>
            <li class="nav-item"><i class="fa-regular fa-user"></i> Mon compte</li>
            <li class="nav-item"><i class="fa-solid fa-user-group"></i> Utilisateurs</li>
        </ul>

        <div class="sidebar-bottom nav-list">
            <li class="nav-item"><i class="fa-regular fa-moon"></i> Mode sombre</li>
            <li class="nav-item"><i class="fa-solid fa-arrow-right-from-bracket"></i> Déconnexion</li>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="main-content">
        
        <header class="topbar">
            <div>
                <h1 class="page-title">Abonnement</h1>
                <p class="page-subtitle">Gérez votre forfait et vos informations de facturation</p>
            </div>
            <div style="display:flex; gap:16px; align-items:center;">
                <div class="company-tag">Société : MSL-ITECH</div>
                <div class="user-profile">Junior Tagne</div>
            </div>
        </header>

        <!-- Banner Essai Gratuit avec un meilleur design -->
        <div class="trial-banner">
            <div class="trial-info">
                <h3><i class="fa-solid fa-gift"></i> 13 jours restants</h3>
                <p>Fin d'essai le 04 août 2026</p>
            </div>
            <div class="trial-text">
                Choisissez un forfait ci-dessous pour continuer à utiliser Sentinelle après votre essai.
            </div>
        </div>

        <!-- Plan Actuel -->
        <div class="current-plan-card">
            <div class="plan-header">
                <p>Forfait en cours d'essai</p>
                <h2>Standard</h2>
            </div>
            
            <div class="plan-features-grid">
                <div class="feature-item"><i class="fa-solid fa-check"></i> 1 société Odoo connectée</div>
                <div class="feature-item"><i class="fa-solid fa-check"></i> Tous les dashboards analytiques</div>
                <div class="feature-item"><i class="fa-solid fa-check"></i> Prévisions Prophet</div>
                <div class="feature-item"><i class="fa-solid fa-check"></i> Chatbot IA intégré</div>
                <div class="feature-item"><i class="fa-solid fa-check"></i> Export Excel</div>
            </div>
            
            <div class="plan-footer">
                <button class="btn btn-outline">Gérer mon abonnement →</button>
            </div>
        </div>

        <h3 class="section-title">Changer de forfait</h3>

        <!-- Grille des prix avec Illustrations Iconographiques -->
        <div class="pricing-grid">
            
            <!-- Starter -->
            <div class="pricing-card">
                <div class="illustration-icon icon-starter"><i class="fa-solid fa-paper-plane"></i></div>
                <h3>Starter</h3>
                <div class="price">49 €/mois</div>
                <ul class="pricing-features">
                    <li><i class="fa-solid fa-check"></i> 1 société Odoo connectée</li>
                    <li><i class="fa-solid fa-check"></i> Dashboard de rentabilité</li>
                    <li><i class="fa-solid fa-check"></i> Export Excel</li>
                    <li><i class="fa-solid fa-check"></i> Recommandations IA (clé API personnelle)</li>
                </ul>
                <button class="btn btn-outline">↓ Rétrograder</button>
            </div>

            <!-- Standard (Actuel) -->
            <div class="pricing-card" style="border: 1px solid var(--primary-light); background: #FAFAFF;">
                <div class="illustration-icon icon-standard"><i class="fa-solid fa-rocket"></i></div>
                <h3>Standard <span class="badge-current">Actuel</span></h3>
                <div class="price">129 €/mois</div>
                <ul class="pricing-features">
                    <li><i class="fa-solid fa-check"></i> 1 société Odoo connectée</li>
                    <li><i class="fa-solid fa-check"></i> Tous les dashboards analytiques</li>
                    <li><i class="fa-solid fa-check"></i> Prévisions Prophet</li>
                    <li><i class="fa-solid fa-check"></i> Chatbot IA intégré</li>
                    <li><i class="fa-solid fa-check"></i> Export Excel</li>
                </ul>
                <button class="btn btn-outline" disabled style="opacity: 0.5; cursor: not-allowed;">Sélectionné</button>
            </div>

            <!-- Premium (Mise en avant) -->
            <div class="pricing-card highlight">
                <div class="highlight-badge">RECOMMANDÉ</div>
                <div class="illustration-icon icon-premium"><i class="fa-solid fa-crown"></i></div>
                <h3>Premium</h3>
                <div class="price">299 €/mois</div>
                <ul class="pricing-features">
                    <li><i class="fa-solid fa-check"></i> Jusqu'à 10 sociétés Odoo</li>
                    <li><i class="fa-solid fa-check"></i> Vue consolidée multi-sociétés</li>
                    <li><i class="fa-solid fa-check"></i> Tous les dashboards analytiques</li>
                    <li><i class="fa-solid fa-check"></i> Prévisions Prophet avancées</li>
                    <li><i class="fa-solid fa-check"></i> Chatbot IA intégré</li>
                    <li><i class="fa-solid fa-check"></i> Publication Odoo Knowledge</li>
                    <li><i class="fa-solid fa-check"></i> Export Excel</li>
                </ul>
                <button class="btn btn-primary">↑ Passer à Premium</button>
            </div>

            <!-- Enterprise -->
            <div class="pricing-card">
                <div class="illustration-icon icon-enterprise"><i class="fa-solid fa-building"></i></div>
                <h3>Enterprise</h3>
                <div class="price">Sur devis</div>
                <ul class="pricing-features">
                    <li><i class="fa-solid fa-check"></i> Sociétés illimitées</li>
                    <li><i class="fa-solid fa-check"></i> Vue consolidée multi-sociétés</li>
                    <li><i class="fa-solid fa-check"></i> Tous les dashboards analytiques</li>
                    <li><i class="fa-solid fa-check"></i> Prévisions Prophet avancées</li>
                    <li><i class="fa-solid fa-check"></i> Chatbot IA intégré</li>
                    <li><i class="fa-solid fa-check"></i> Support prioritaire</li>
                    <li><i class="fa-solid fa-check"></i> Accès API</li>
                </ul>
                <button class="btn btn-outline" style="background:#FFF7ED; color:#F97316; border-color:#FED7AA;">Contacter les ventes</button>
            </div>
        </div>

        <!-- Paiement & Historique (Empty States avec Illustrations CSS) -->
        
        <div style="display: flex; justify-content: space-between; align-items: flex-end;">
            <h3 class="section-title"><i class="fa-regular fa-credit-card" style="color:var(--text-light)"></i> Moyens de paiement</h3>
            <button class="btn btn-primary" style="margin-bottom: 20px;"><i class="fa-solid fa-plus"></i> Ajouter une carte</button>
        </div>
        
        <!-- Bloc Image / Illustration pour Aucun moyen de paiement -->
        <div class="empty-state-card">
            <div class="illustration-wrapper">
                <div class="illus-bg-blob"></div>
                <i class="fa-solid fa-wallet illus-icon"></i>
            </div>
            <p>Aucun moyen de paiement enregistré.</p>
            <button class="btn btn-primary"><i class="fa-solid fa-plus"></i> Ajouter une carte bancaire</button>
        </div>

        <h3 class="section-title"><i class="fa-solid fa-file-invoice" style="color:var(--text-light)"></i> Historique de facturation</h3>
        
        <!-- Bloc Image / Illustration pour Aucune facture -->
        <div class="empty-state-card">
            <div class="illustration-wrapper">
                <div class="illus-bg-blob" style="background: #F1F5F9; animation-duration: 10s;"></div>
                <i class="fa-solid fa-box-open illus-icon" style="color: #94A3B8; filter: none;"></i>
            </div>
            <p style="margin-bottom: 4px;">Aucune facture disponible pour le moment.</p>
            <p style="font-size: 13px; font-weight: 400;">Les factures apparaîtront après le premier paiement.</p>
        </div>

        <div class="footer-support">
            Une question sur votre abonnement ? <a href="#">Contacter le support</a>
        </div>

    </main>

</body>
</html>